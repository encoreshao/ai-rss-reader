# ─────────────────────────────────────────────────────────
#  deploy.config — server configuration for deploy.sh
#
#  Copy this file to scripts/deploy.config and fill in your values.
#  deploy.config is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────

SERVER="user@your-server.com"       # SSH target (user@host)
APP_DIR="/var/www/production/your-app/app"  # Absolute path on server
APP_NAME="your-app"                 # PM2 process name
SITE_URL="https://your-app.com"     # Public URL used to verify deployment
